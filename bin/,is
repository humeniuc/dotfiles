#!/bin/bash

SCRIPT_DIR="$(dirname "$( readlink -f "${BASH_SOURCE[0]}" )")"

_error_message() {
    [ -n "$1" ] && {
        echo "$1" >&2
        command -v /bin/notify-send >/dev/null && notify-send -- "$1"
    }
}

_exit() {
    [ -n "$1" ] && _error_message "$1"
    exit "${2:-1}"
}

_meta_checks() {
    echo help list test not any all
}

_list_checks() {
    local f opt
    while read -r f; do
        opt=${f#_is_}
        case " $(_meta_checks) " in
            *" $opt "*) continue ;;
        esac
        echo "$opt"
    done < <(compgen -A function | grep '^_is_' | sort)
}

_run_check() {
    local fn="_is_$1"

    if declare -f "$fn" >/dev/null; then
        "$fn"
        return $?
    fi

    _error_message "unknown check: $1"
    return 2
}

_is_sway() {
    [[ ":${XDG_CURRENT_DESKTOP}:" == *:sway:* ]] && return 0 || return 1
}

_is_wlroots() {
    [[ ":${XDG_CURRENT_DESKTOP}:" == *:wlroots:* ]] && return 0 || return 1
}

_is_wayland() {
    [ "$XDG_SESSION_TYPE" == "wayland" ] && return 0 || return 1
}

_is_xorg() {
    [ "$XDG_SESSION_TYPE" == "x11" ] && return 0 || return 1
}

_is_x11() {
    _is_xorg
}

_is_i3() {
    [[ ":${XDG_CURRENT_DESKTOP}:" == *:i3:* ]] && return 0 || return 1
}

_is_i3wm() {
    _is_i3
}

_is_tmux() {
    [ -n "$TMUX" ] && return 0 || return 1
}

_is_screen() {
    [ -n "$STY" ] && return 0 || return 1
}

_is_multiplexer() {
    [ -n "$TMUX" ] || [ -n "$STY" ] && return 0 || return 1
}

_is_git() {
    command -v git >/dev/null 2>&1 &&
        git rev-parse --is-inside-work-tree >/dev/null 2>&1 &&
        return 0 || return 1
}

_is_graphical() {
    [ -n "$WAYLAND_DISPLAY" ] || [ -n "$DISPLAY" ] && return 0 || return 1
}

_is_headless() {
    _is_graphical && return 1 || return 0
}

_is_interactive() {
    [ -t 0 ] && return 0 || return 1
}

_is_ssh() {
    [ -n "$SSH_CONNECTION" ] || [ -n "$SSH_TTY" ] && return 0 || return 1
}

_is_pipe() {
    [ ! -t 0 ] && return 0 || return 1
}

_is_not() {
    local rc

    [ $# -eq 1 ] || return 2
    _run_check "$1"
    rc=$?
    [ "$rc" -eq 2 ] && return 2
    [ "$rc" -eq 0 ] && return 1 || return 0
}

_is_any() {
    local check

    [ $# -gt 0 ] || return 2
    for check in "$@"; do
        _run_check "$check" && return 0
    done
    return 1
}

_is_all() {
    local check

    [ $# -gt 0 ] || return 2
    for check in "$@"; do
        _run_check "$check" || return 1
    done
    return 0
}

_is_list() {
    _list_checks
}

_is_test() {
    local t

    while read -r t; do
        echo "$t:" $(_run_check "$t" && echo 1 || echo 0)
    done < <(_list_checks)
}

_is_help() {
    cat <<'EOF'
,is — test the current environment

Usage: ,is [options] <command> [checks...]

Options:
  -p, --print  print true or false in addition to the exit status

Commands:
  list         list available checks
  test         run all checks and print 1 (true) or 0 (false) for each
  help         show this help
  not <check>  true when <check> is false
  any <checks> true when at least one check is true
  all <checks> true when every check is true
  <check>      run a single check

Checks:
  sway         XDG_CURRENT_DESKTOP contains sway
  wlroots      XDG_CURRENT_DESKTOP contains wlroots
  wayland      XDG_SESSION_TYPE is wayland
  xorg, x11    XDG_SESSION_TYPE is x11
  i3wm, i3     XDG_CURRENT_DESKTOP contains i3
  tmux         running inside a tmux session
  screen       running inside a GNU screen session
  multiplexer  running inside tmux or screen
  git          current directory is inside a git work tree
  graphical    WAYLAND_DISPLAY or DISPLAY is set
  headless     no graphical display available
  interactive  stdin is a terminal
  ssh          SSH_CONNECTION or SSH_TTY is set
  pipe         stdin is not a terminal

Exit status is 0 when the condition is true, 1 when it is false.
EOF
}

main()
{
    local print=0
    local -a args=()
    local cmd rc

    while [ $# -gt 0 ]; do
        case "$1" in
            -p|--print)
                print=1
                shift
                ;;
            -h|--help)
                args+=(help)
                shift
                ;;
            *)
                args+=("$1")
                shift
                ;;
        esac
    done

    [ ${#args[@]} -eq 0 ] && args=(help)

    cmd=${args[0]}
    case "$cmd" in
        not|any|all)
            [ ${#args[@]} -lt 2 ] && _exit "usage: ,is $cmd <check> [checks...]"
            _is_$cmd "${args[@]:1}"
            rc=$?
            ;;
        *)
            _run_check "$cmd"
            rc=$?
            ;;
    esac

    [ "$rc" -eq 2 ] && _exit

    if [ "$print" -eq 1 ]; then
        [ "$rc" -eq 0 ] && echo true || echo false
    fi

    exit "$rc"
}

main "$@"
